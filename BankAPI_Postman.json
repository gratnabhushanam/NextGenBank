{
  "info": {
    "name": "NextGen Banking System API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "http://localhost:5000/api/auth/register", "host": ["localhost"], "port": "5000", "path": ["api", "auth", "register"] }
          }
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "http://localhost:5000/api/auth/login", "host": ["localhost"], "port": "5000", "path": ["api", "auth", "login"] }
          }
        }
      ]
    },
    {
      "name": "Accounts",
      "item": [
        {
          "name": "Create Account",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "http://localhost:5000/api/accounts", "host": ["localhost"], "port": "5000", "path": ["api", "accounts"] }
          }
        },
        {
          "name": "Deposit Funds",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "http://localhost:5000/api/accounts/deposit", "host": ["localhost"], "port": "5000", "path": ["api", "accounts", "deposit"] }
          }
        },
        {
          "name": "Withdraw Funds",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "http://localhost:5000/api/accounts/withdraw", "host": ["localhost"], "port": "5000", "path": ["api", "accounts", "withdraw"] }
          }
        },
        {
          "name": "Transfer Funds",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "http://localhost:5000/api/accounts/transfer", "host": ["localhost"], "port": "5000", "path": ["api", "accounts", "transfer"] }
          }
        }
      ]
    }
  ]
}
